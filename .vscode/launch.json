{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch Test Package",
			"type": "go",
			"request": "launch",
			"mode": "test",
			"program": "${file}",
			"args": [
				"check-go-version",
				"false"
			]
		},
		{
			"name": "Debug Test Function",
			"type": "go",
			"request": "launch",
			"mode": "test",
			"program": "${fileDirname}",
			"args": [
				"-test.v",
				"-test.run",
				"${selectedText}"
			],
			"env": {
				"CHECKPOINT_DISABLE": "1",
				"TF_IN_AUTOMATION": "1"
			}
		},
		{
			"name": "Attach to Process",
			"type": "go",
			"request": "attach",
			"mode": "local",
			"processId": "${command:pickProcess}"
		}
	]
}