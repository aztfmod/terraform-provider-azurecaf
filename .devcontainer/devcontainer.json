// For format details, see https://aka.ms/devcontainers/json
{
    "name": "Azure CAF Terraform Provider",

    "image": "mcr.microsoft.com/devcontainers/base:jammy",
    "remoteUser": "vscode",

    // Persist Go module cache and Terraform plugin cache across container rebuilds
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/tmp/.ssh-localhost,type=bind,consistency=cached",
        "source=azurecaf-go-mod-cache,target=/home/vscode/go,type=volume",
        "source=azurecaf-terraform-cache,target=/home/vscode/.terraform.d,type=volume"
    ],

    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined"
    ],

    "features": {
        "ghcr.io/devcontainers/features/go:1": {
            "version": "1.25"
        },
        "ghcr.io/devcontainers/features/terraform:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/azure-cli:1": {},
        "ghcr.io/azure/azure-dev/azd:latest": {},
        "ghcr.io/devcontainers-extra/features/zsh-plugins:0": {
            "plugins": [
                "aliases",
                "syntax-highlighting",
                "autosuggestions"
            ],
            "username": "vscode"
        }
    },

    "containerEnv": {
        "CHECKPOINT_DISABLE": "1",
        "TF_IN_AUTOMATION": "1",
        "TF_CLI_ARGS_init": "-upgrade=false"
    },

    "postCreateCommand": "bash .devcontainer/postCreateCommand.sh",

    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "hashicorp.terraform",
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "eamodio.gitlens",
                "mutantdino.resourcemonitor"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh",
                "go.gopath": "/home/vscode/go",
                "go.lintTool": "golangci-lint",
                "go.lintOnSave": "workspace",
                "go.testFlags": ["-v"],
                "editor.formatOnSave": true,
                "[go]": {
                    "editor.defaultFormatter": "golang.go"
                }
            }
        }
    }
}